# Config knobs for the partial GPS-sender (see lib/config.dart).
# Flutter does NOT auto-read this file — either edit lib/config.dart defaults,
# or pass these as --dart-define flags (see SETUP.md). This file just documents them.

API_BASE=http://10.0.2.2:8000   # emulator->host; real phone uses your LAN IP
HELPER_TOKEN=                    # JWT from POST /auth/login (approved helper)
BUS_ID=                         # buses.id UUID from scripts.dev_seed_fleet
