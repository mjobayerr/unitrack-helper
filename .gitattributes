# Normalize everything to LF in the repo; check out native on Windows.
* text=auto eol=lf

# Scripts whose line endings are load-bearing.
*.bat  text eol=crlf
*.ps1  text eol=crlf
gradlew text eol=lf

# Never touch these.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.jar      binary
*.keystore binary
*.jks      binary
